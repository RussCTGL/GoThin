# Anthropic API key for the app's Claude calls.
# NOTE: this is billed separately from a Claude Max plan (pay-per-token).
# Max covers your interactive use; app/API traffic is metered on the Console.
# Create a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (OPTIONAL). Leave all unset to run in demo mode (in-memory store,
# auth disabled). Set all three to enable Postgres persistence AND auth.
# From your Supabase project: Settings → API.
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...        # public — safe in the browser
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...                 # server-only secret — never expose to the browser

# Admin accounts (OPTIONAL) — comma-separated emails that can see /admin
# (system-wide AI usage across all users). Matched against the signed-in email.
# ADMIN_EMAILS=you@example.com
